---
import AppShell from "../layouts/AppShell.astro";
import { AvContainer, AvButton } from "@ansiversa/components";

const title = "Daily Word Challenge | Ansiversa";
const description = "A premium daily word learning tracker for focused vocabulary growth.";
---

<AppShell title={title} description={description}>
  <section class="border-b border-white/10 bg-gradient-to-b from-slate-900 via-slate-950 to-slate-950 py-24">
    <AvContainer size="narrow">
      <div class="space-y-6 text-center">
        <p class="text-xs uppercase tracking-[0.24em] text-slate-400">Ansiversa Mini App</p>
        <h1 class="text-4xl font-semibold tracking-tight text-white md:text-5xl">Build your vocabulary habit,<br />one word each day.</h1>
        <p class="mx-auto max-w-2xl text-base text-slate-300 md:text-lg">
          Daily Word Challenge keeps your personal word learning clean and consistent.
          Capture terms, assign challenge dates, and track completion without clutter.
        </p>
        <div class="flex items-center justify-center gap-3">
          <AvButton href="/app">Open Workspace</AvButton>
          <AvButton href="#features" variant="secondary">See Features</AvButton>
        </div>
      </div>
    </AvContainer>
  </section>

  <section id="features" class="py-16">
    <AvContainer size="narrow">
      <div class="grid gap-4 md:grid-cols-3">
        <article class="rounded-2xl border border-white/10 bg-white/[0.03] p-5">
          <h2 class="text-lg font-semibold text-white">Personal Word Vault</h2>
          <p class="mt-2 text-sm text-slate-300">Store term, meaning, examples, and categories in one calm workspace.</p>
        </article>
        <article class="rounded-2xl border border-white/10 bg-white/[0.03] p-5">
          <h2 class="text-lg font-semibold text-white">Challenge Routine</h2>
          <p class="mt-2 text-sm text-slate-300">Assign challenge dates, mark completed, and keep your streak of consistency alive.</p>
        </article>
        <article class="rounded-2xl border border-white/10 bg-white/[0.03] p-5">
          <h2 class="text-lg font-semibold text-white">Focused Progress</h2>
          <p class="mt-2 text-sm text-slate-300">Favorites, archive history, and high-signal dashboard summaries in the Ansiversa ecosystem.</p>
        </article>
      </div>
    </AvContainer>
  </section>
</AppShell>
