---
import AppShell from "../../layouts/AppShell.astro";
import AvMiniAppBar from "../../components/AvMiniAppBar.astro";
import { listDailyWords, buildDailyWordSummary } from "../../lib/daily-words";

const user = Astro.locals.user;
if (!user) {
  return Astro.redirect("/");
}

const words = await listDailyWords(user.id);
const summary = buildDailyWordSummary(words);
---

<AppShell title="Daily Word Challenge Workspace" description="Track your daily vocabulary growth.">
  <AvMiniAppBar appKey="daily-word-challenge" appName="Daily Word Challenge" userName={user.name ?? user.email} />

  <main class="mx-auto max-w-6xl space-y-6 px-4 py-6 md:px-6" x-data x-init={`$store.dailyWords.init(${JSON.stringify(words).replace(/`/g, "\\`")})`}>
    <section class="grid gap-3 sm:grid-cols-2 xl:grid-cols-6">
      <article class="rounded-xl border border-white/10 bg-white/[0.03] p-4"><p class="text-xs text-slate-400">Total</p><p class="text-2xl font-semibold text-white" x-text="$store.dailyWords.summary.totalWords">{summary.totalWords}</p></article>
      <article class="rounded-xl border border-white/10 bg-white/[0.03] p-4"><p class="text-xs text-slate-400">Active</p><p class="text-2xl font-semibold text-white" x-text="$store.dailyWords.summary.activeWords">{summary.activeWords}</p></article>
      <article class="rounded-xl border border-white/10 bg-white/[0.03] p-4"><p class="text-xs text-slate-400">Completed</p><p class="text-2xl font-semibold text-white" x-text="$store.dailyWords.summary.completedWords">{summary.completedWords}</p></article>
      <article class="rounded-xl border border-white/10 bg-white/[0.03] p-4"><p class="text-xs text-slate-400">Favorites</p><p class="text-2xl font-semibold text-white" x-text="$store.dailyWords.summary.favoriteWords">{summary.favoriteWords}</p></article>
      <article class="rounded-xl border border-white/10 bg-white/[0.03] p-4"><p class="text-xs text-slate-400">Archived</p><p class="text-2xl font-semibold text-white" x-text="$store.dailyWords.summary.archivedWords">{summary.archivedWords}</p></article>
      <article class="rounded-xl border border-white/10 bg-white/[0.03] p-4"><p class="text-xs text-slate-400">Today</p><p class="text-2xl font-semibold text-white" x-text="$store.dailyWords.summary.todaysChallengeCount">{summary.todaysChallengeCount}</p></article>
    </section>

    <section class="rounded-2xl border border-white/10 bg-slate-950/70 p-4 md:p-5">
      <div class="flex flex-wrap items-center justify-between gap-3">
        <div class="flex flex-wrap gap-2">
          <template x-for="tab in ['overview','words','favorites','archived']" :key="tab">
            <button
              type="button"
              class="rounded-full border border-white/10 px-3 py-1.5 text-sm text-slate-300"
              :class="$store.dailyWords.activeTab === tab ? 'bg-white text-slate-900' : 'hover:bg-white/5'"
              x-text="tab.charAt(0).toUpperCase() + tab.slice(1)"
              @click="$store.dailyWords.setActiveTab(tab)"
            ></button>
          </template>
        </div>
        <button type="button" class="rounded-full bg-white px-4 py-2 text-sm font-medium text-slate-900" @click="$store.dailyWords.openCreateDrawer()">+ New Word</button>
      </div>

      <div class="mt-4 grid gap-3 md:grid-cols-4">
        <input x-model="$store.dailyWords.searchQuery" type="search" placeholder="Search terms or meaning" class="rounded-lg border border-white/10 bg-slate-900 px-3 py-2 text-sm text-white md:col-span-2" />
        <select x-model="$store.dailyWords.statusFilter" class="rounded-lg border border-white/10 bg-slate-900 px-3 py-2 text-sm text-white">
          <option value="all">All States</option>
          <option value="pending">Pending</option>
          <option value="completed">Completed</option>
        </select>
        <select x-model="$store.dailyWords.categoryFilter" class="rounded-lg border border-white/10 bg-slate-900 px-3 py-2 text-sm text-white">
          <template x-for="category in $store.dailyWords.categories" :key="category">
            <option :value="category" x-text="category === 'all' ? 'All Categories' : category"></option>
          </template>
        </select>
      </div>

      <p class="mt-3 text-sm" :class="$store.dailyWords.flashType === 'error' ? 'text-rose-300' : 'text-emerald-300'" x-show="$store.dailyWords.flashMessage" x-text="$store.dailyWords.flashMessage"></p>

      <div class="mt-4 space-y-3" x-show="$store.dailyWords.filteredWords.length > 0">
        <template x-for="word in $store.dailyWords.filteredWords" :key="word.id">
          <article class="rounded-xl border border-white/10 bg-white/[0.03] p-4">
            <div class="flex flex-wrap items-start justify-between gap-2">
              <div>
                <a :href="`/app/words/${word.id}`" class="text-lg font-semibold text-white hover:underline" x-text="word.term"></a>
                <p class="mt-1 text-sm text-slate-300 line-clamp-2" x-text="word.meaning"></p>
              </div>
              <div class="flex gap-2">
                <button @click="$store.dailyWords.toggleFavorite(word)" class="rounded-md border border-white/10 px-2 py-1 text-xs text-slate-200" x-text="word.isFavorite ? '★ Favorite' : '☆ Favorite'"></button>
                <button @click="$store.dailyWords.toggleCompleted(word)" class="rounded-md border border-white/10 px-2 py-1 text-xs text-slate-200" x-text="word.isCompleted ? 'Completed' : 'Mark complete'"></button>
              </div>
            </div>
            <div class="mt-3 flex flex-wrap gap-2 text-xs text-slate-400">
              <span class="rounded-full border border-white/10 px-2 py-1" x-text="word.category ?? 'Uncategorized'"></span>
              <span class="rounded-full border border-white/10 px-2 py-1" x-text="word.challengeDate ? `Challenge: ${new Date(word.challengeDate).toLocaleDateString()}` : 'No challenge date'"></span>
              <span class="rounded-full border border-white/10 px-2 py-1" x-text="word.status"></span>
            </div>
            <div class="mt-3 flex gap-2 text-xs">
              <button @click="$store.dailyWords.openEditDrawer(word)" class="rounded-md border border-white/10 px-2 py-1 text-slate-300">Edit</button>
              <button x-show="word.status === 'active'" @click="$store.dailyWords.archiveWord(word)" class="rounded-md border border-amber-400/30 px-2 py-1 text-amber-200">Archive</button>
              <button x-show="word.status === 'archived'" @click="$store.dailyWords.restoreWord(word)" class="rounded-md border border-emerald-400/30 px-2 py-1 text-emerald-200">Restore</button>
            </div>
          </article>
        </template>
      </div>

      <div class="mt-8 rounded-xl border border-dashed border-white/15 bg-white/[0.02] p-8 text-center text-sm text-slate-400" x-show="$store.dailyWords.filteredWords.length === 0">
        No words found for your current search/filter.
      </div>
    </section>

    <section x-show="$store.dailyWords.isDrawerOpen" class="fixed inset-0 z-40 flex justify-end bg-slate-900/70" @click.self="$store.dailyWords.closeDrawer()">
      <div class="h-full w-full max-w-md overflow-y-auto border-l border-white/10 bg-slate-950 p-5">
        <h2 class="text-lg font-semibold text-white" x-text="$store.dailyWords.isEditing ? 'Edit word' : 'Create word'"></h2>
        <form class="mt-4 space-y-3" @submit.prevent="$store.dailyWords.submitForm()">
          <input x-model="$store.dailyWords.form.term" required placeholder="Term" class="w-full rounded-lg border border-white/10 bg-slate-900 px-3 py-2 text-sm text-white" />
          <textarea x-model="$store.dailyWords.form.meaning" required placeholder="Meaning" class="min-h-24 w-full rounded-lg border border-white/10 bg-slate-900 px-3 py-2 text-sm text-white"></textarea>
          <textarea x-model="$store.dailyWords.form.exampleText" placeholder="Usage example" class="min-h-20 w-full rounded-lg border border-white/10 bg-slate-900 px-3 py-2 text-sm text-white"></textarea>
          <input x-model="$store.dailyWords.form.category" placeholder="Category" class="w-full rounded-lg border border-white/10 bg-slate-900 px-3 py-2 text-sm text-white" />
          <input x-model="$store.dailyWords.form.challengeDate" type="date" class="w-full rounded-lg border border-white/10 bg-slate-900 px-3 py-2 text-sm text-white" />
          <div class="flex gap-2 pt-2">
            <button type="button" class="rounded-md border border-white/10 px-3 py-2 text-sm text-slate-300" @click="$store.dailyWords.closeDrawer()">Cancel</button>
            <button type="submit" class="rounded-md bg-white px-3 py-2 text-sm font-medium text-slate-900" :disabled="$store.dailyWords.isSubmitting" x-text="$store.dailyWords.isSubmitting ? 'Saving...' : 'Save word'"></button>
          </div>
        </form>
      </div>
    </section>
  </main>
</AppShell>
