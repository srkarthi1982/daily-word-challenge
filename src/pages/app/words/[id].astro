---
import AppShell from "../../../layouts/AppShell.astro";
import AvMiniAppBar from "../../../components/AvMiniAppBar.astro";
import { getDailyWordDetail } from "../../../lib/daily-words";

const user = Astro.locals.user;
if (!user) {
  return Astro.redirect("/");
}

const id = Number(Astro.params.id);
if (!Number.isFinite(id) || id <= 0) {
  return Astro.redirect("/app");
}

const word = await getDailyWordDetail(user.id, id);
if (!word) {
  return new Response("Not found", { status: 404 });
}
---

<AppShell title={`${word.term} | Daily Word Challenge`} description={word.meaning}>
  <AvMiniAppBar appKey="daily-word-challenge" appName="Daily Word Challenge" userName={user.name ?? user.email} />

  <main class="mx-auto max-w-3xl space-y-5 px-4 py-6 md:px-6">
    <a href="/app" class="inline-flex items-center gap-2 rounded-full border border-white/10 px-3 py-1 text-sm text-slate-300 hover:bg-white/5">← Back to workspace</a>

    <article class="rounded-2xl border border-white/10 bg-white/[0.03] p-6">
      <div class="flex flex-wrap items-start justify-between gap-3">
        <div>
          <p class="text-xs uppercase tracking-[0.2em] text-slate-400">Word Detail</p>
          <h1 class="mt-1 text-3xl font-semibold text-white">{word.term}</h1>
        </div>
        <div class="flex gap-2 text-xs">
          <span class="rounded-full border border-white/10 px-2 py-1 text-slate-200">{word.isFavorite ? "Favorite" : "Not favorite"}</span>
          <span class="rounded-full border border-white/10 px-2 py-1 text-slate-200">{word.isCompleted ? "Completed" : "Pending"}</span>
          <span class="rounded-full border border-white/10 px-2 py-1 text-slate-200">{word.status}</span>
        </div>
      </div>

      <dl class="mt-6 space-y-5">
        <div>
          <dt class="text-xs uppercase tracking-wide text-slate-400">Meaning</dt>
          <dd class="mt-1 text-base text-slate-100">{word.meaning}</dd>
        </div>
        <div>
          <dt class="text-xs uppercase tracking-wide text-slate-400">Usage Example</dt>
          <dd class="mt-1 text-base text-slate-200">{word.exampleText ?? "No example provided."}</dd>
        </div>
        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <dt class="text-xs uppercase tracking-wide text-slate-400">Category</dt>
            <dd class="mt-1 text-slate-200">{word.category ?? "Uncategorized"}</dd>
          </div>
          <div>
            <dt class="text-xs uppercase tracking-wide text-slate-400">Challenge Date</dt>
            <dd class="mt-1 text-slate-200">{word.challengeDate ? new Date(word.challengeDate).toLocaleDateString() : "Not assigned"}</dd>
          </div>
        </div>

        <div class="grid gap-4 sm:grid-cols-3">
          <div>
            <dt class="text-xs uppercase tracking-wide text-slate-400">Created</dt>
            <dd class="mt-1 text-slate-300">{new Date(word.createdAt).toLocaleString()}</dd>
          </div>
          <div>
            <dt class="text-xs uppercase tracking-wide text-slate-400">Updated</dt>
            <dd class="mt-1 text-slate-300">{new Date(word.updatedAt).toLocaleString()}</dd>
          </div>
          <div>
            <dt class="text-xs uppercase tracking-wide text-slate-400">Completed</dt>
            <dd class="mt-1 text-slate-300">{word.completedAt ? new Date(word.completedAt).toLocaleString() : "Not completed yet"}</dd>
          </div>
        </div>
      </dl>
    </article>
  </main>
</AppShell>
