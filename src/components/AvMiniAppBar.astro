---
interface Props {
  appName: string;
  appKey: string;
  logoPath?: string;
  userName?: string;
}

const { appName, appKey, logoPath = "/favicon.svg", userName } = Astro.props;
---

<header class="border-b border-white/10 bg-slate-950/90 backdrop-blur">
  <div class="mx-auto flex max-w-6xl items-center justify-between px-4 py-3 md:px-6">
    <a href="/app" class="flex items-center gap-3 text-white">
      <img src={logoPath} alt={`${appName} logo`} class="h-7 w-7 rounded" />
      <div>
        <p class="text-xs uppercase tracking-[0.2em] text-slate-400">{appKey}</p>
        <p class="text-sm font-semibold">{appName}</p>
      </div>
    </a>
    <div class="flex items-center gap-2 text-sm text-slate-300">
      <a class="rounded-full border border-white/10 px-3 py-1.5 hover:bg-white/5" href="/">Home</a>
      {userName && <span class="hidden text-slate-400 md:inline">{userName}</span>}
    </div>
  </div>
</header>
